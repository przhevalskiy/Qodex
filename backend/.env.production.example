# ===========================================
# Qodex Backend Production Environment Variables
# ===========================================
# Set these in your Render dashboard under Environment settings

# Supabase Database Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# AI Provider API Keys
OPENAI_API_KEY=sk-your-openai-key  # Required for Pinecone embeddings (text-embedding-3-small)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
MISTRAL_API_KEY=your-mistral-key

# Pinecone Vector Database
PINECONE_API_KEY=your-pinecone-key
PINECONE_HOST=https://your-index.pinecone.io
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=qodex-documents

# Application Configuration
# Set this to your Render frontend URL after deployment
CORS_ORIGINS=https://qodex-frontend.onrender.com
DEBUG=false
LOG_LEVEL=INFO

# Optional: Default AI Models
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
MISTRAL_MODEL=mistral-large-latest
